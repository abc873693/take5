# 複製此檔為 .env 並填入你自己的值
# cp .env.example .env

# 必填 ──────────────────────────────────
COMPANY_CODE=ACME
EMAIL=alice@example.com
PASSWORD=your_password_here

# 打卡座標（GPS）
LATITUDE=25.0330
LONGITUDE=121.5654

# 選填 ──────────────────────────────────
# 'in' = 上班；其他值或留空 = 下班/統一打卡
# 也可以從命令列覆寫: npx tsx take5-clock.ts in
IN_OUT=in

# 後端登入會驗證 deviceId 非空（空字串會 400 {"error":"DeviceIdEmpty"}）
# App 端送的是 Capacitor Device.getId()：Android = ANDROID_ID（16 字元 hex）、iOS = identifierForVendor UUID
# 留空 script 會自動生成一組並印在 log，建議把生成的值寫回此處以維持同一裝置身分
DEVICE_ID=

# android | ios | androidchina | wecomios | wecomandroid | other
DEVICE_TYPE=android

# 設成 1 就無視上面的 LATITUDE/LONGITUDE，
# 改用後端 machine 設定的中心點座標（保證在 range 內，最容易讓打卡記錄被當成「正規」打卡）
USE_MACHINE_LOCATION=0
